GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000
# Required in production (min 16 characters). Optional in development (a dev default is used).
AUTH_JWT_SECRET=

# If the frontend is on another domain (e.g. Vercel) and the API on Render, set:
# SESSION_COOKIE_SAMESITE=none
# (Required for httpOnly session cookies on cross-origin requests; uses Secure cookies.)
